#!/bin/bash
###############################################################################
# backup_zabbix_basico.sh
#
# Coleta apenas os arquivos ESSENCIAIS para Disaster Recovery:
#   - Configs principais do Zabbix (server, proxy, agente)
#   - Includes dos agentes (.d/)
#   - PostgreSQL (postgresql.conf, pg_hba.conf)
#   - HAProxy (haproxy.cfg)
#   - Export via API: Templates, Value Mappings, Macros Globais
#
# Usa /tmp como area de trabalho e limpa tudo apos o push.
###############################################################################

set -uo pipefail

# ===========================================================================
# CONFIGURACOES
# ===========================================================================
GIT_USER="usr_zabbix"
GIT_TOKEN="xzeeQpPycx7tT6HBh1Ks"
GIT_HOST="gitlab.local"
GIT_PROJECT="zbx/Zabbix"
GIT_BRANCH="backups"
GIT_REPO_URL="https://${GIT_USER}:${GIT_TOKEN}@${GIT_HOST}/${GIT_PROJECT}.git"

ZABBIX_API_URL="https://zbx-web.crefisa.com.br/zabbix/api_jsonrpc.php"
ZABBIX_API_USER="usr_zabbix_prd"
ZABBIX_API_PASS="P#UD7!5ohr"

HOSTNAME_ID=$(hostname -s | tr '[:upper:]' '[:lower:]')
LOG_FILE="/var/log/backup_zabbix_basico.log"

# Area de trabalho temporaria - removida apos o push
GIT_REPO_LOCAL=$(mktemp -d /tmp/backup-zabbix-XXXX)

DEST="${GIT_REPO_LOCAL}/${HOSTNAME_ID}"

# ===========================================================================
# FUNCOES
# ===========================================================================
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

# Copia um arquivo para a subpasta de destino, apenas se ele existir
coletar() {
    local subpasta="$1"
    local origem="$2"
    local destino="${DEST}/${subpasta}"

    [ ! -e "$origem" ] && return
    mkdir -p "$destino"
    if cp -p "$origem" "$destino/" 2>/dev/null; then
        log "  [OK] ${subpasta}/$(basename "$origem")"
    else
        log "  [ERRO] Falha ao copiar: ${origem}"
    fi
}

# Copia todos os arquivos (nao recursivo) de um diretorio
coletar_dir() {
    local subpasta="$1"
    local dir="$2"
    [ ! -d "$dir" ] && return
    local destino="${DEST}/${subpasta}"
    mkdir -p "$destino"
    for f in "$dir"/*; do
        if [ -f "$f" ]; then
            cp -p "$f" "$destino/" 2>/dev/null
            log "  [OK] ${subpasta}/$(basename "$f")"
        fi
    done
}

# ===========================================================================
# 1. PREPARAR REPOSITORIO GIT EM /tmp
# ===========================================================================
log "============================================================"
log "INICIANDO BACKUP - ${HOSTNAME_ID}"
log "============================================================"

export GIT_TERMINAL_PROMPT=0
export GIT_SSL_NO_VERIFY=1

log ">>> Clonando repositorio GitLab em ${GIT_REPO_LOCAL}..."
git clone --branch master "$GIT_REPO_URL" "$GIT_REPO_LOCAL" 2>>"$LOG_FILE" || {
    log "[FATAL] Falha ao clonar repositorio."
    rm -rf "$GIT_REPO_LOCAL"
    exit 1
}

cd "$GIT_REPO_LOCAL"

# Cria/troca para branch de backups
if git ls-remote --exit-code --heads origin "$GIT_BRANCH" 2>/dev/null; then
    git checkout -b "$GIT_BRANCH" origin/"$GIT_BRANCH" 2>>"$LOG_FILE"
else
    log ">>> Criando branch '${GIT_BRANCH}'..."
    git checkout -b "$GIT_BRANCH" 2>>"$LOG_FILE"
    git push -u origin "$GIT_BRANCH" 2>>"$LOG_FILE" || {
        log "[FATAL] Falha ao criar branch '${GIT_BRANCH}' no GitLab."
        rm -rf "$GIT_REPO_LOCAL"
        exit 1
    }
fi

git config user.email "${GIT_USER}@crefisa.com.br"
git config user.name "Backup Zabbix - ${HOSTNAME_ID}"

# Recria pasta limpa deste servidor
rm -rf "$DEST"
mkdir -p "$DEST"

# ===========================================================================
# 2. COLETA DE CONFIGURACOES ESSENCIAIS
# ===========================================================================
log ">>> Coletando arquivos de configuracao..."

# --- Zabbix Server ---
coletar "zabbix-server" "/etc/zabbix/zabbix_server.conf"

# --- Zabbix Proxy ---
coletar "zabbix-proxy" "/etc/zabbix/zabbix_proxy.conf"

# --- Zabbix Agent (versao C) ---
coletar "zabbix-agent" "/etc/zabbix/zabbix_agentd.conf"
coletar_dir "zabbix-agent/agentd.d" "/etc/zabbix/zabbix_agentd.d"

# --- Zabbix Agent 2 (versao Go) ---
coletar "zabbix-agent2" "/etc/zabbix/zabbix_agent2.conf"
coletar_dir "zabbix-agent2/agent2.d" "/etc/zabbix/zabbix_agent2.d"

# --- PostgreSQL ---
for pg_dir in /etc/postgresql/*/main /var/lib/pgsql/*/data /var/lib/pgsql/data; do
    [ -d "$pg_dir" ] || continue
    coletar "postgresql" "${pg_dir}/postgresql.conf"
    coletar "postgresql" "${pg_dir}/pg_hba.conf"
done

# --- HAProxy ---
coletar "haproxy" "/etc/haproxy/haproxy.cfg"
coletar_dir "haproxy/conf.d" "/etc/haproxy/conf.d"

# --- Inventario minimo ---
mkdir -p "${DEST}/00-inventario"
{
    echo "=== Inventario: $(hostname) - $(date) ==="
    echo ""
    echo "--- OS ---"
    cat /etc/os-release 2>/dev/null
    echo ""
    echo "--- Kernel ---"
    uname -a
    echo ""
    echo "--- Servicos Zabbix ---"
    for svc in zabbix-server zabbix-proxy zabbix-agent zabbix-agent2; do
        status=$(systemctl is-active "$svc" 2>/dev/null || echo "nao-instalado")
        enabled=$(systemctl is-enabled "$svc" 2>/dev/null || echo "nao-instalado")
        echo "  $svc: $status (enabled: $enabled)"
    done
    echo ""
    echo "--- Pacotes Zabbix instalados ---"
    rpm -qa 2>/dev/null | grep -i zabbix | sort || dpkg -l 2>/dev/null | grep -i zabbix || echo "nao foi possivel listar"
} > "${DEST}/00-inventario/inventario.txt"
log "  [OK] 00-inventario/inventario.txt"

# ===========================================================================
# 3. EXPORTACAO VIA API ZABBIX
#    Somente no host onde zabbix-server esta instalado (conf existe)
# ===========================================================================
if [ -f /etc/zabbix/zabbix_server.conf ]; then
    log ">>> Exportando dados via API Zabbix..."
    API_DIR="${DEST}/zabbix-api"
    mkdir -p "$API_DIR"

    # Login
    API_TOKEN=$(curl -k -s -X POST "${ZABBIX_API_URL}" -H "Content-Type: application/json" -d "{\"jsonrpc\":\"2.0\",\"method\":\"user.login\",\"params\":{\"username\":\"${ZABBIX_API_USER}\",\"password\":\"${ZABBIX_API_PASS}\"},\"id\":1}" | grep -oP '"result":"\K[^"]+' 2>/dev/null)

    if [ -n "$API_TOKEN" ]; then
        log "  [OK] Login na API realizado."

        # --- Templates (inclui Itens, Triggers, LLD e Macros de template) ---
        log "  [+] Exportando Templates..."
        TIDS=$(curl -k -s -X POST "${ZABBIX_API_URL}" -H "Content-Type: application/json" -d "{\"jsonrpc\":\"2.0\",\"method\":\"template.get\",\"params\":{\"output\":[\"templateid\"]},\"auth\":\"${API_TOKEN}\",\"id\":2}" | python3 -c "import sys,json; print(','.join(t['templateid'] for t in json.load(sys.stdin).get('result',[])))" 2>/dev/null)

        if [ -n "$TIDS" ]; then
            TIDS_JSON=$(python3 -c "ids='${TIDS}'.split(','); print('['+','.join('\"'+i+'\"' for i in ids)+']')" 2>/dev/null)
            curl -k -s -X POST "${ZABBIX_API_URL}" -H "Content-Type: application/json" -d "{\"jsonrpc\":\"2.0\",\"method\":\"configuration.export\",\"params\":{\"options\":{\"templates\":${TIDS_JSON}},\"format\":\"xml\"},\"auth\":\"${API_TOKEN}\",\"id\":3}" | python3 -c "import sys,json; print(json.load(sys.stdin).get('result',''))" 2>/dev/null > "${API_DIR}/templates_completos.xml"
            if [ -s "${API_DIR}/templates_completos.xml" ]; then
                log "  [OK] zabbix-api/templates_completos.xml"
            else
                log "  [ERRO] templates_completos.xml vazio"
            fi
        fi

        # --- Value Mappings ---
        log "  [+] Exportando Value Mappings..."
        curl -k -s -X POST "${ZABBIX_API_URL}" -H "Content-Type: application/json" -d "{\"jsonrpc\":\"2.0\",\"method\":\"valuemap.get\",\"params\":{\"output\":\"extend\",\"selectMappings\":\"extend\"},\"auth\":\"${API_TOKEN}\",\"id\":4}" | python3 -c "import sys,json; json.dump(json.load(sys.stdin).get('result',[]),sys.stdout,indent=2)" 2>/dev/null > "${API_DIR}/value_mappings.json"
        if [ -s "${API_DIR}/value_mappings.json" ]; then
            log "  [OK] zabbix-api/value_mappings.json"
        else
            log "  [ERRO] value_mappings.json vazio"
        fi

        # --- Macros Globais ---
        log "  [+] Exportando Macros Globais..."
        curl -k -s -X POST "${ZABBIX_API_URL}" -H "Content-Type: application/json" -d "{\"jsonrpc\":\"2.0\",\"method\":\"usermacro.get\",\"params\":{\"output\":\"extend\",\"globalmacro\":true},\"auth\":\"${API_TOKEN}\",\"id\":5}" | python3 -c "import sys,json; json.dump(json.load(sys.stdin).get('result',[]),sys.stdout,indent=2)" 2>/dev/null > "${API_DIR}/macros_globais.json"
        if [ -s "${API_DIR}/macros_globais.json" ]; then
            log "  [OK] zabbix-api/macros_globais.json"
        else
            log "  [ERRO] macros_globais.json vazio"
        fi

        # Logout
        curl -k -s -X POST "${ZABBIX_API_URL}" -H "Content-Type: application/json" -d "{\"jsonrpc\":\"2.0\",\"method\":\"user.logout\",\"params\":[],\"auth\":\"${API_TOKEN}\",\"id\":6}" >/dev/null
    else
        log "  [ERRO] Falha no login na API Zabbix."
    fi
fi

# ===========================================================================
# 4. GERAR README.md
# ===========================================================================
log ">>> Atualizando README.md..."
{
    echo "# Backup de Configurações Zabbix - Crefisa"
    echo ""
    echo "> Atualizado automaticamente. Última execução: **${HOSTNAME_ID}** em \`$(date '+%Y-%m-%d %H:%M:%S')\`"
    echo ""
    echo "## Estrutura"
    echo ""
    echo "| Subpasta | Conteúdo |"
    echo "|---|---|"
    echo "| \`00-inventario/\` | OS, kernel, pacotes e estado dos serviços |"
    echo "| \`zabbix-server/\` | \`zabbix_server.conf\` |"
    echo "| \`zabbix-proxy/\` | \`zabbix_proxy.conf\` |"
    echo "| \`zabbix-agent/\` | \`zabbix_agentd.conf\` + includes de \`.d/\` |"
    echo "| \`zabbix-agent2/\` | \`zabbix_agent2.conf\` + includes de \`.d/\` |"
    echo "| \`zabbix-api/\` | \`templates_completos.xml\`, \`value_mappings.json\`, \`macros_globais.json\` |"
    echo "| \`postgresql/\` | \`postgresql.conf\`, \`pg_hba.conf\` |"
    echo "| \`haproxy/\` | \`haproxy.cfg\` |"
    echo ""
    echo "## Servidores"
    echo ""
    for srv in "${GIT_REPO_LOCAL}"/*/; do
        nome=$(basename "$srv")
        [[ "$nome" == .git ]] && continue
        [ ! -d "$srv" ] && continue
        echo "### \`${nome}\`"
        for sub in "$srv"*/; do
            [ -d "$sub" ] || continue
            count=$(find "$sub" -maxdepth 1 -type f 2>/dev/null | wc -l)
            echo "- \`$(basename "$sub")/\` — ${count} arquivo(s)"
        done
        echo ""
    done
    echo "## Restauração (DR)"
    echo ""
    echo "1. Copie os arquivos \`.conf\` da pasta do servidor para seus locais originais em \`/etc/zabbix/\`"
    echo "2. Importe \`templates_completos.xml\` via **Configuração → Templates → Importar** no Zabbix"
    echo "3. Importe os Value Mappings via API ou interface"
    echo ""
    echo "> ⚠️ Este repositório contém credenciais. Mantenha acesso restrito."
} > "${GIT_REPO_LOCAL}/README.md"
log "  [OK] README.md atualizado."

# ===========================================================================
# 5. COMMIT & PUSH
# ===========================================================================
log ">>> Enviando ao GitLab..."
cd "$GIT_REPO_LOCAL"

git add -A "${HOSTNAME_ID}/" README.md 2>>"$LOG_FILE"

if git diff --cached --quiet 2>/dev/null; then
    log "  Nenhuma alteracao nesta execucao."
else
    git commit -m "backup(${HOSTNAME_ID}): $(date '+%Y-%m-%d %H:%M')" 2>>"$LOG_FILE"
fi

PUSH_OK=0
for tentativa in 1 2 3; do
    if git push origin "$GIT_BRANCH" 2>>"$LOG_FILE"; then
        PUSH_OK=1
        log "  [OK] Enviado com sucesso!"
        break
    else
        log "  [RETRY] Tentativa ${tentativa}/3 - aguardando e tentando rebase..."
        git pull --rebase origin "$GIT_BRANCH" 2>>"$LOG_FILE" || true
        sleep $((RANDOM % 10 + 5))
    fi
done

[ "$PUSH_OK" -eq 0 ] && log "  [ERRO] Falha ao enviar apos 3 tentativas."

# ===========================================================================
# 6. LIMPEZA - remove o clone temporario do /tmp
# ===========================================================================
log ">>> Removendo area temporaria: ${GIT_REPO_LOCAL}"
rm -rf "$GIT_REPO_LOCAL"
log "  [OK] Limpeza concluida."

log "============================================================"
log "FIM DO BACKUP - ${HOSTNAME_ID}"
log "============================================================"
